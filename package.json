{
  "name": "backend-folder-gen",
  "displayName": "Backend Folder Structure Generator",
  "description": "Generate clean backend architecture for Go (Gin)",
  "version": "0.0.1",
  "publisher": "saai",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:backendArchGen.generateGoStructure"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/SAAI-JAGAN/Architecture_Scaffold_Engine/releases/tag/v1.0.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "backendArchGen.generateGoStructure",
        "title": "Generate Clean Go Backend Structure"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}